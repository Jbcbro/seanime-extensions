{
    "id": "jbcbro-dub-tracker",
    "name": "Dub Tracker",
    "version": "4.0.0",
    "manifestURI": "https://raw.githubusercontent.com/Jbcbro/seanime-extensions/main/extensions/dub-tracker/manifest.json",
    "language": "typescript",
    "type": "plugin",
    "description": "Shows CC and DUB episode counts on anime thumbnails from a prebuilt AniList-ID dataset.",
    "author": "Jbcbro",
    "icon": "https://raw.githubusercontent.com/Bas1874/MyDubList-Seanime/refs/heads/main/src/icons/logo.png",
    "payloadURI": "https://raw.githubusercontent.com/Jbcbro/seanime-extensions/main/extensions/dub-tracker/plugin.ts",
    "plugin": {
        "version": "1",
        "permissions": {
            "scopes": [
                "storage"
            ],
            "allow": {
                "networkAccess": {
                    "allowedDomains": [
                        "raw.githubusercontent.com"
                    ],
                    "reasoning": "Loads the prebuilt Dub Tracker counts dataset from this repository."
                },
                "unsafeFlags": [
                    {
                        "flag": "dom-script-manipulation"
                    }
                ]
            }
        }
    },
    "isDevelopment": false
}
