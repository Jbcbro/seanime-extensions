{
    "id": "jbcbro-dub-tracker",
    "name": "Dub Tracker",
    "version": "3.2.0",
    "manifestURI": "https://raw.githubusercontent.com/Jbcbro/seanime-extensions/main/extensions/dub-tracker/manifest.json",
    "language": "typescript",
    "type": "plugin",
    "description": "Shows CC and DUB episode counts on anime thumbnails.",
    "author": "Jbcbro",
    "icon": "https://raw.githubusercontent.com/Bas1874/MyDubList-Seanime/refs/heads/main/src/icons/logo.png",
    "payloadURI": "https://raw.githubusercontent.com/Jbcbro/seanime-extensions/main/extensions/dub-tracker/plugin.ts",
    "plugin": {
        "version": "1",
        "permissions": {
            "allow": {
                "networkAccess": {
                    "allowedDomains": [
                        "graphql.anilist.co",
                        "aniwatch-api.jc-server.com",
                        "anime-db.videasy.net"
                    ],
                    "reasoning": "AniList GraphQL for title lookup and AniWatch-compatible APIs for sub/dub episode counts."
                },
                "unsafeFlags": [
                    {
                        "flag": "dom-script-manipulation"
                    }
                ]
            }
        }
    },
    "isDevelopment": false
}
